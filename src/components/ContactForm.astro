---
interface Props {
  compact?: boolean;
}

const { compact = false } = Astro.props;
---

<section class={`${compact ? 'py-16' : 'py-20 lg:py-28'} bg-white`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    {/* Header */}
    <div class="text-center mb-12 lg:mb-16">
      {compact ? (
        <>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 rounded-full mb-6">
            <span class="w-2 h-2 bg-slate-900 rounded-full"></span>
            <span class="text-sm font-semibold text-slate-700 tracking-wide uppercase">Get Started</span>
          </div>
          <h2 class="text-3xl sm:text-4xl font-bold text-slate-900 mb-4">
            Ready to Fix Your Digital Foundation?
          </h2>
          <p class="text-lg text-slate-600 max-w-2xl mx-auto">
            Every great digital presence starts with understanding what's broken.
          </p>
        </>
      ) : (
        <>
          <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 rounded-full mb-6">
            <span class="w-2 h-2 bg-slate-900 rounded-full"></span>
            <span class="text-sm font-semibold text-slate-700 tracking-wide uppercase">Contact</span>
          </div>
          <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6">
            Let's Build Your Foundation
          </h2>
          <p class="text-lg lg:text-xl text-slate-600 max-w-2xl mx-auto leading-relaxed">
            Every great digital presence starts with a conversation about what's not working. 
            Tell me about your situation, and I'll provide a clear assessment of what needs to be fixed.
          </p>
        </>
      )}
    </div>

    {/* Form */}
    <form 
      id="contactForm"
      method="POST" 
      action="/api/contact"
      class="bg-slate-50 rounded-2xl p-6 lg:p-10 border border-slate-200"
    >
      {/* Business Information Section */}
      <div class="mb-10">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-blue-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-slate-900">Business Information</h3>
            <p class="text-sm text-slate-600">Help me understand your business context</p>
          </div>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6">
          {/* Business Type */}
          <div>
            <label for="business-type" class="block text-sm font-semibold text-slate-900 mb-2">
              Business Type <span class="text-red-500">*</span>
            </label>
            <select 
              id="business-type" 
              name="business-type" 
              required
              class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all hover:border-slate-300"
            >
              <option value="">Select your business type</option>
              <option value="homestay">Homestay / Tourism Property</option>
              <option value="clinic">Clinic / Healthcare</option>
              <option value="restaurant">Restaurant / Food Business</option>
              <option value="retail">Retail / Service Business</option>
              <option value="other">Other</option>
            </select>
          </div>

          {/* Website Status */}
          <div>
            <label for="website-status" class="block text-sm font-semibold text-slate-900 mb-2">
              Current Website Status <span class="text-red-500">*</span>
            </label>
            <select 
              id="website-status" 
              name="website-status" 
              required
              class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all hover:border-slate-300"
            >
              <option value="">Select current status</option>
              <option value="none">No website</option>
              <option value="outdated">Outdated / Not mobile-friendly</option>
              <option value="working">Working but not getting results</option>
              <option value="broken">Broken or not loading</option>
            </select>
          </div>
        </div>
      </div>

      {/* Project Details Section */}
      <div class="mb-10 pt-8 border-t border-slate-200">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-purple-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-slate-900">Project Details</h3>
            <p class="text-sm text-slate-600">What you're looking to achieve</p>
          </div>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6">
          {/* Budget */}
          <div>
            <label for="budget" class="block text-sm font-semibold text-slate-900 mb-2">
              Budget Range <span class="text-red-500">*</span>
            </label>
            <select 
              id="budget" 
              name="budget" 
              required
              class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all hover:border-slate-300"
            >
              <option value="">Select budget range</option>
              <option value="under-25k">Under ₹25,000</option>
              <option value="25k-50k">₹25,000 - ₹50,000</option>
              <option value="50k-75k">₹50,000 - ₹75,000</option>
              <option value="75k+">₹75,000+</option>
            </select>
          </div>

          {/* Primary Pain */}
          <div>
            <label for="primary-pain" class="block text-sm font-semibold text-slate-900 mb-2">
              Biggest Challenge <span class="text-red-500">*</span>
            </label>
            <select 
              id="primary-pain" 
              name="primary-pain" 
              required
              class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all hover:border-slate-300"
            >
              <option value="">What's your biggest challenge?</option>
              <option value="not-found">Not found on Google</option>
              <option value="no-inquiries">No website inquiries</option>
              <option value="outdated">Website looks outdated</option>
              <option value="mobile">Not mobile-friendly</option>
              <option value="competition">Losing to competitors</option>
              <option value="other">Other</option>
            </select>
          </div>
        </div>
      </div>

      {/* Contact Information Section */}
      <div class="mb-10 pt-8 border-t border-slate-200">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-slate-900">Contact Information</h3>
            <p class="text-sm text-slate-600">How I can reach you</p>
          </div>
        </div>
        
        <div class="grid md:grid-cols-2 gap-6 mb-6">
          {/* Name */}
          <div>
            <label for="name" class="block text-sm font-semibold text-slate-900 mb-2">
              Your Name <span class="text-red-500">*</span>
            </label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required
              placeholder="John Doe"
              class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all hover:border-slate-300 placeholder:text-slate-400"
            />
          </div>

          {/* Email */}
          <div>
            <label for="email" class="block text-sm font-semibold text-slate-900 mb-2">
              Email Address <span class="text-red-500">*</span>
            </label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required
              placeholder="john@example.com"
              class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all hover:border-slate-300 placeholder:text-slate-400"
            />
          </div>
        </div>

        {/* Phone */}
        <div>
          <label for="phone" class="block text-sm font-semibold text-slate-900 mb-2">
            Phone Number <span class="text-red-500">*</span>
          </label>
          <input 
            type="tel" 
            id="phone" 
            name="phone" 
            required
            placeholder="+91 98765 43210"
            class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all hover:border-slate-300 placeholder:text-slate-400"
          />
        </div>
      </div>

      {/* Additional Details Section */}
      <div class="mb-10 pt-8 border-t border-slate-200">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-10 h-10 bg-orange-100 rounded-xl flex items-center justify-center">
            <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-slate-900">Additional Details</h3>
            <p class="text-sm text-slate-600">Anything else I should know?</p>
          </div>
        </div>
        
        <div>
          <label for="message" class="block text-sm font-semibold text-slate-900 mb-2">
            Tell me more about your situation
            <span class="text-slate-400 font-normal">(optional)</span>
          </label>
          <textarea 
            id="message" 
            name="message" 
            rows={4}
            placeholder="Any additional details about your current website or business goals..."
            class="w-full px-4 py-3 bg-white border-2 border-slate-200 rounded-xl text-slate-900 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none transition-all hover:border-slate-300 placeholder:text-slate-400 resize-none"
          ></textarea>
        </div>
      </div>

      {/* Submit Section */}
      <div class="pt-8 border-t border-slate-200">
        <div class="flex flex-col sm:flex-row items-center justify-between gap-6">
          <div class="flex items-center gap-4 text-sm text-slate-600">
            <div class="flex items-center gap-1.5">
              <svg class="w-5 h-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5 9V7a5 5 0 0110 0v2a2 2 0 012 2v5a2 2 0 01-2 2H5a2 2 0 01-2-2v-5a2 2 0 012-2zm8-2v2H7V7a3 3 0 016 0z" clip-rule="evenodd" />
              </svg>
              <span>SSL Secure</span>
            </div>
            <div class="flex items-center gap-1.5">
              <svg class="w-5 h-5 text-blue-500" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
              </svg>
              <span>24hr Response</span>
            </div>
          </div>
          
          <button 
            type="submit"
            class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-slate-900 text-white font-semibold rounded-xl hover:bg-slate-800 hover:shadow-lg hover:scale-105 transition-all duration-300 group"
          >
            <span>Start the Conversation</span>
            <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </button>
        </div>
      </div>
    </form>
  </div>
</section>

<script>
  // Premium form validation and interactions
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contactForm') as HTMLFormElement;
    if (!form) return;
    
    const inputs = form.querySelectorAll('.form-input-premium') as NodeListOf<HTMLInputElement>;
    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    
    // Real-time validation
    inputs.forEach(input => {
      input.addEventListener('blur', () => validateField(input));
      input.addEventListener('input', () => {
        if (input.parentElement && (input.parentElement.classList.contains('success') || input.parentElement.classList.contains('error'))) {
          validateField(input);
        }
      });
    });
    
    // Form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Validate all fields
      let isValid = true;
      inputs.forEach(input => {
        if (!validateField(input)) {
          isValid = false;
        }
      });
      
      if (!isValid) {
        // Show error for first invalid field
        const firstInvalid = form.querySelector('.form-input-premium.error') as HTMLInputElement;
        if (firstInvalid) {
          firstInvalid.focus();
          firstInvalid.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        return;
      }
      
      // Show loading state
      form.classList.add('loading');
      let originalText = '';
      if (submitButton) {
        submitButton.disabled = true;
        originalText = submitButton.innerHTML;
        submitButton.innerHTML = `
          <span class="relative z-10 flex items-center space-x-2">
            <svg class="w-5 h-5 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            <span>Sending...</span>
          </span>
        `;
      }
      
      try {
        const formData = new FormData(form);
        const response = await fetch('/api/contact', {
          method: 'POST',
          body: formData,
          headers: {
            'Accept': 'application/json',
          },
        });
        
        if (response.ok) {
          // Show success message
          showFormMessage('success', 'Message Sent!', 'Thank you for reaching out. I\'ll get back to you within 24 hours with a clear assessment of your situation.');
          form.reset();
          inputs.forEach(input => {
            if (input.parentElement) {
              input.parentElement.classList.remove('success', 'error');
            }
          });
        } else {
          throw new Error('Form submission failed');
        }
      } catch (error) {
        // Show error message
        showFormMessage('error', 'Something went wrong', 'Please try again or contact me directly at [your-email].');
      } finally {
        // Reset button state
        form.classList.remove('loading');
        if (submitButton) {
          submitButton.disabled = false;
          submitButton.innerHTML = originalText;
        }
      }
    });
    
    function validateField(input: HTMLInputElement): boolean {
      const formGroup = input.parentElement;
      const errorElement = formGroup?.querySelector('.form-error') as HTMLElement;
      let isValid = true;
      let errorMessage = '';
      
      // Remove previous states
      formGroup?.classList.remove('success', 'error');
      errorElement?.classList.remove('show');
      
      // Check if required and empty
      if (input.hasAttribute('required') && !input.value.trim()) {
        isValid = false;
        errorMessage = `Please enter ${getInputLabel(input)}`;
      }
      
      // Email validation
      if (input.type === 'email' && input.value.trim()) {
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
        if (!emailRegex.test(input.value.trim())) {
          isValid = false;
          errorMessage = 'Please enter a valid email address';
        }
      }
      
      // Phone validation (basic)
      if (input.type === 'tel' && input.value.trim()) {
        const phoneRegex = /^[+]?[\d\s\-\(\)]+$/;
        if (!phoneRegex.test(input.value.trim()) || input.value.trim().length < 10) {
          isValid = false;
          errorMessage = 'Please enter a valid phone number';
        }
      }
      
      // Apply validation state
      if (!isValid && formGroup) {
        formGroup.classList.add('error');
        input.classList.add('error');
        if (errorElement) {
          errorElement.textContent = errorMessage;
          errorElement.classList.add('show');
        }
      } else if (input.value.trim() && formGroup) {
        formGroup.classList.add('success');
        input.classList.remove('error');
      }
      
      return isValid;
    }
    
    function getInputLabel(input: HTMLInputElement): string {
      const label = form?.querySelector(`label[for="${input.id}"]`) as HTMLLabelElement;
      if (label) {
        return label.textContent.replace('*', '').trim() || '';
      }
      return input.name || 'this field';
    }
    
    function showFormMessage(type: 'success' | 'error', title: string, message: string): void {
      // Remove any existing messages
      const existingMessage = form?.querySelector('.form-success, .form-error-message');
      if (existingMessage) {
        existingMessage.remove();
      }
      
      // Create message element
      const messageDiv = document.createElement('div');
      messageDiv.className = type === 'success' ? 'form-success' : 'form-error-message';
      messageDiv.innerHTML = `
        <h3>${title}</h3>
        <p>${message}</p>
      `;
      
      // Insert after form
      if (form?.parentNode) {
        form.parentNode.insertBefore(messageDiv, form.nextSibling);
      }
      
      // Scroll to message
      messageDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
      
      // Auto-remove after 10 seconds for success messages
      if (type === 'success') {
        setTimeout(() => {
          messageDiv.style.opacity = '0';
          setTimeout(() => messageDiv.remove(), 300);
        }, 10000);
      }
    }
    
    // Add input focus effects
    inputs.forEach(input => {
      input.addEventListener('focus', () => {
        if (input.parentElement) {
          input.parentElement.classList.add('focused');
        }
      });
      
      input.addEventListener('blur', () => {
        if (input.parentElement) {
          input.parentElement.classList.remove('focused');
        }
      });
    });
  });
</script>
