---
import type { Service } from '@/types';
import { services } from '@/data/services';

interface Props {
  showTitle?: boolean;
}

const { showTitle = true } = Astro.props;
---

<section id="services" class="py-20 lg:py-28 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 xl:px-12">
    {showTitle && (
      <div class="text-center mb-16 lg:mb-20 max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-slate-100 rounded-full mb-6">
          <span class="w-2 h-2 bg-slate-900 rounded-full"></span>
          <span class="text-sm font-semibold text-slate-700 tracking-wide uppercase">Complete System</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6 leading-tight">
          The Complete Digital Infrastructure System
        </h2>
        <p class="text-lg lg:text-xl text-slate-600 leading-relaxed">
          Four interconnected parts that work together to make your business permanently discoverable. Never sold separately because they only work as a complete system.
        </p>
      </div>
    )}

    <div class="grid md:grid-cols-2 gap-6 lg:gap-8">
      {services.map((service, index) => {
        const colorMap = [
          { bg: 'bg-blue-50', border: 'border-blue-200', icon: 'text-blue-600', iconBg: 'bg-blue-100', hover: 'hover:border-blue-300 hover:shadow-blue-100' },
          { bg: 'bg-purple-50', border: 'border-purple-200', icon: 'text-purple-600', iconBg: 'bg-purple-100', hover: 'hover:border-purple-300 hover:shadow-purple-100' },
          { bg: 'bg-orange-50', border: 'border-orange-200', icon: 'text-orange-600', iconBg: 'bg-orange-100', hover: 'hover:border-orange-300 hover:shadow-orange-100' },
          { bg: 'bg-teal-50', border: 'border-teal-200', icon: 'text-teal-600', iconBg: 'bg-teal-100', hover: 'hover:border-teal-300 hover:shadow-teal-100' }
        ];
        const colors = colorMap[index % colorMap.length];
        
        const iconMap = {
          'heroicons:lightning-bolt': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>',
          'heroicons:arrow-path': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>',
          'heroicons:cpu-chip': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 002-2V7a2 2 0 00-2-2H7a2 2 0 00-2 2v10a2 2 0 002 2zM9 9h6v6H9V9z"/></svg>',
          'heroicons:chart-bar': '<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>'
        };
        
        return (
          <div class={`group relative ${colors.bg} rounded-2xl p-6 lg:p-8 border-2 ${colors.border} transition-all duration-300 hover:shadow-xl ${colors.hover} hover:-translate-y-1`}>
            {/* Card Header */}
            <div class="flex items-start gap-4 mb-6">
              <div class={`shrink-0 w-14 h-14 ${colors.iconBg} rounded-xl flex items-center justify-center transition-transform group-hover:scale-110 group-hover:rotate-3`}>
                <div class={colors.icon} set:html={iconMap[service.icon as keyof typeof iconMap]}></div>
              </div>
              <div class="flex-1 min-w-0">
                <h3 class="text-xl lg:text-2xl font-bold text-slate-900 mb-2 group-hover:text-slate-800 transition-colors">
                  {service.title}
                </h3>
                <p class="text-slate-600 leading-relaxed">
                  {service.description}
                </p>
              </div>
            </div>
            
            {/* Features List */}
            <div class="mb-6">
              <h4 class="font-semibold text-slate-900 mb-3 text-sm tracking-wide uppercase">What's Included</h4>
              <ul class="space-y-2">
                {service.features.map((feature) => (
                  <li class="flex items-start gap-3 text-slate-600">
                    <div class="shrink-0 w-5 h-5 bg-white rounded-full flex items-center justify-center shadow-sm mt-0.5">
                      <svg class="w-3 h-3 text-green-600" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                      </svg>
                    </div>
                    <span class="text-sm leading-relaxed">{feature}</span>
                  </li>
                ))}
              </ul>
            </div>
            
            {/* Outcome Card */}
            <div class="bg-white rounded-xl p-5 border border-slate-200 shadow-sm">
              <div class="flex items-center gap-2 mb-2">
                <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                <span class="font-semibold text-slate-900 text-sm">Outcome</span>
              </div>
              <p class="text-slate-600 text-sm leading-relaxed">{service.outcome}</p>
            </div>

            {/* Hover Arrow */}
            <div class="absolute top-6 right-6 opacity-0 group-hover:opacity-100 transition-opacity">
              <div class="w-10 h-10 bg-white rounded-full shadow-lg flex items-center justify-center">
                <svg class="w-5 h-5 text-slate-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                </svg>
              </div>
            </div>
          </div>
        );
      })}
    </div>

    {/* Bottom CTA */}
    <div class="mt-16 text-center">
      <div class="inline-flex flex-col sm:flex-row items-center gap-4 bg-slate-50 rounded-2xl p-6 lg:p-8 border border-slate-200">
        <div class="text-center sm:text-left">
          <p class="font-semibold text-slate-900 mb-1">Ready to get the complete system?</p>
          <p class="text-slate-600 text-sm">All four parts working together for your business.</p>
        </div>
        <a 
          href="/contact" 
          class="shrink-0 inline-flex items-center gap-2 px-6 py-3 bg-slate-900 text-white font-semibold rounded-xl hover:bg-slate-800 hover:shadow-lg transition-all duration-300 group"
        >
          <span>Get Started</span>
          <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
