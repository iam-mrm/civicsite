---
import type { CaseStudy } from '@/types';
import { caseStudies } from '@/data/services';

interface Props {
  limit?: number;
  showTitle?: boolean;
}

const { limit = caseStudies.length, showTitle = true } = Astro.props;
const featuredStudies = caseStudies.slice(0, limit);
---

<section class="py-20 lg:py-28 bg-slate-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 xl:px-12">
    {showTitle && (
      <div class="text-center mb-16 lg:mb-20 max-w-3xl mx-auto">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-white rounded-full border border-slate-200 mb-6">
          <span class="w-2 h-2 bg-green-500 rounded-full"></span>
          <span class="text-sm font-semibold text-slate-700 tracking-wide uppercase">Success Stories</span>
        </div>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold text-slate-900 mb-6 leading-tight">
          Real Results for Kerala Businesses
        </h2>
        <p class="text-lg lg:text-xl text-slate-600 leading-relaxed">
          Technical foundation that produces measurable business outcomes.
        </p>
      </div>
    )}

    <div class="space-y-8 lg:space-y-12">
      {featuredStudies.map((study, index) => (
        <div class="group bg-white rounded-2xl p-6 lg:p-10 border border-slate-200 shadow-sm hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
          <div class="grid lg:grid-cols-2 gap-8 lg:gap-12">
            {/* Left Column - Challenge & Solution */}
            <div>
              {/* Header */}
              <div class="flex flex-wrap items-center gap-3 mb-4">
                <span class="px-4 py-1.5 bg-slate-100 text-slate-700 rounded-full text-sm font-semibold">
                  {study.industry}
                </span>
                <span class="text-slate-400 text-sm">{study.client}</span>
              </div>
              
              <h3 class="text-2xl lg:text-3xl font-bold text-slate-900 mb-6">{study.client}</h3>
              
              {/* Challenge */}
              <div class="mb-6 p-5 bg-red-50 rounded-xl border border-red-100">
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-8 h-8 bg-red-100 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L3.732 16.5c-.77.833.192 2.5 1.732 2.5z" />
                    </svg>
                  </div>
                  <h4 class="font-bold text-red-900">The Challenge</h4>
                </div>
                <p class="text-red-800 leading-relaxed">{study.challenge}</p>
              </div>
              
              {/* Solution */}
              <div class="mb-6 p-5 bg-blue-50 rounded-xl border border-blue-100">
                <div class="flex items-center gap-2 mb-3">
                  <div class="w-8 h-8 bg-blue-100 rounded-lg flex items-center justify-center">
                    <svg class="w-4 h-4 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <h4 class="font-bold text-blue-900">The Solution</h4>
                </div>
                <p class="text-blue-800 leading-relaxed">{study.solution}</p>
              </div>

              {/* Testimonial */}
              {study.testimonial && (
                <div class="bg-slate-50 rounded-xl p-5 border-l-4 border-slate-900">
                  <svg class="w-6 h-6 text-slate-400 mb-2" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
                  </svg>
                  <p class="text-slate-700 italic leading-relaxed">"{study.testimonial}"</p>
                </div>
              )}
            </div>

            {/* Right Column - Results & Metrics */}
            <div class="lg:pl-8 lg:border-l lg:border-slate-200">
              {/* Results */}
              <div class="mb-8">
                <div class="flex items-center gap-2 mb-4">
                  <div class="w-10 h-10 bg-green-100 rounded-xl flex items-center justify-center">
                    <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
                    </svg>
                  </div>
                  <h4 class="text-xl font-bold text-slate-900">Results Achieved</h4>
                </div>
                <ul class="space-y-3">
                  {study.results.map((result) => (
                    <li class="flex items-start gap-3 p-3 bg-green-50/50 rounded-lg border border-green-100">
                      <div class="shrink-0 w-6 h-6 bg-green-500 rounded-full flex items-center justify-center mt-0.5">
                        <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                        </svg>
                      </div>
                      <span class="text-slate-700 leading-relaxed">{result}</span>
                    </li>
                  ))}
                </ul>
              </div>

              {/* Before/After Metrics */}
              {(study.beforeMetrics || study.afterMetrics) && (
                <div class="grid grid-cols-2 gap-4">
                  {study.beforeMetrics && (
                    <div class="bg-red-50 rounded-xl p-5 border border-red-200">
                      <div class="flex items-center gap-2 mb-3">
                        <div class="w-2 h-2 bg-red-500 rounded-full"></div>
                        <span class="font-bold text-red-900 text-sm uppercase tracking-wide">Before</span>
                      </div>
                      {study.beforeMetrics.lighthouse && (
                        <div class="mb-2">
                          <span class="text-sm text-red-700">Lighthouse: </span>
                          <span class="font-bold text-red-900 text-lg">{study.beforeMetrics.lighthouse}</span>
                        </div>
                      )}
                      {study.beforeMetrics.discoverability && (
                        <div>
                          <span class="text-sm text-red-700">Search: </span>
                          <span class="text-red-900">{study.beforeMetrics.discoverability}</span>
                        </div>
                      )}
                    </div>
                  )}
                  
                  {study.afterMetrics && (
                    <div class="bg-green-50 rounded-xl p-5 border border-green-200">
                      <div class="flex items-center gap-2 mb-3">
                        <div class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></div>
                        <span class="font-bold text-green-900 text-sm uppercase tracking-wide">After</span>
                      </div>
                      {study.afterMetrics.lighthouse && (
                        <div class="mb-2">
                          <span class="text-sm text-green-700">Lighthouse: </span>
                          <span class="font-bold text-green-900 text-lg">{study.afterMetrics.lighthouse}</span>
                        </div>
                      )}
                      {study.afterMetrics.discoverability && (
                        <div>
                          <span class="text-sm text-green-700">Search: </span>
                          <span class="text-green-900">{study.afterMetrics.discoverability}</span>
                        </div>
                      )}
                    </div>
                  )}
                </div>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>

    {/* CTA */}
    <div class="mt-12 text-center">
      <a 
        href="/contact" 
        class="inline-flex items-center gap-2 px-8 py-4 bg-slate-900 text-white font-semibold rounded-xl hover:bg-slate-800 hover:shadow-lg hover:scale-105 transition-all duration-300 group"
      >
        <span>Get Similar Results</span>
        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
