---
import Layout from '../layouts/Layout.astro';
import { siteConfig } from '../data/siteConfig';
import Hero from '../components/Hero.astro';
import ContactForm from '../components/ContactForm.astro';
---

<Layout title="Contact - Start Your Digital Foundation">
  <main class="min-h-screen bg-white">
    
    {/* Hero Section */}
    <Hero 
      title="Let's Build Your Foundation"
      subtitle="Every great digital presence starts with a conversation about what's not working. I'll respond within 24 hours with a clear assessment of your situation."
      showCTA={false}
    />

    {/* Contact Form */}
    <ContactForm />

    {/* What Happens Next */}
    <section class="py-16 bg-slate-50">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-slate-900 mb-8">What Happens Next</h2>
        
        <div class="space-y-6">
          <div class="bg-white rounded-xl p-6 border border-slate-200">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-slate-900 text-white rounded-full flex items-center justify-center font-bold text-sm shrink-0">
                1
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">Initial Response</h3>
                <p class="text-slate-600">
                  I'll review your information and respond within 24 hours with a clear assessment of your situation and whether we're a good fit to work together.
                </p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 border border-slate-200">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-slate-900 text-white rounded-full flex items-center justify-center font-bold text-sm shrink-0">
                2
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">Discovery Call</h3>
                <p class="text-slate-600">
                  If we're a good fit, we'll schedule a 30-minute call to discuss your specific challenges, goals, and what success looks like for your business.
                </p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 border border-slate-200">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-slate-900 text-white rounded-full flex items-center justify-center font-bold text-sm shrink-0">
                3
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">Clear Proposal</h3>
                <p class="text-slate-600">
                  You'll receive a simple, clear proposal with defined scope, timeline, and pricing. No surprises, no hidden fees, no technical jargon.
                </p>
              </div>
            </div>
          </div>

          <div class="bg-white rounded-xl p-6 border border-slate-200">
            <div class="flex items-start gap-4">
              <div class="w-8 h-8 bg-slate-900 text-white rounded-full flex items-center justify-center font-bold text-sm shrink-0">
                4
              </div>
              <div>
                <h3 class="text-lg font-bold text-slate-900 mb-2">Project Kickoff</h3>
                <p class="text-slate-600">
                  If you decide to move forward, we'll start building your digital infrastructure system. Most projects take 2-4 weeks from start to delivery.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* Alternative Contact Methods */}
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-6">
        <h2 class="text-3xl font-bold text-slate-900 mb-8">Other Ways to Reach Out</h2>
        
        <div class="grid md:grid-cols-2 gap-8">
          <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
            <h3 class="text-lg font-bold text-slate-900 mb-4">Direct Email</h3>
            <p class="text-slate-600 mb-4">
              For general questions or if you prefer email communication:
            </p>
            <a href="mailto:hello@kerala-digital.infrastructure" class="text-slate-900 font-medium hover:underline">
              hello@kerala-digital.infrastructure
            </a>
          </div>

          <div class="bg-slate-50 rounded-xl p-6 border border-slate-200">
            <h3 class="text-lg font-bold text-slate-900 mb-4">WhatsApp</h3>
            <p class="text-slate-600 mb-4">
              For quick questions or to schedule a call:
            </p>
            <a href="tel:+919876543210" class="text-slate-900 font-medium hover:underline">
              +91 98765 43210
            </a>
          </div>
        </div>

        <div class="mt-8 text-center">
          <p class="text-slate-600">
            I respond to all inquiries personally. No assistants, no automated responses, no sales team.
          </p>
        </div>
      </div>
    </section>

  </main>
</Layout>
